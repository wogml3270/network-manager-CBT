# Vercel API token입니다. GitHub Actions에서 alias 동기화에 사용하며, 로컬 브라우저에는 노출하면 안 됩니다.
VERCEL_TOKEN=

# Vercel 프로젝트 ID입니다. `.vercel/project.json` 또는 Vercel dashboard에서 확인합니다.
VERCEL_PROJECT_ID=

# Vercel team 프로젝트일 때 사용하는 team ID입니다. 개인 계정 프로젝트라면 비워둡니다.
VERCEL_TEAM_ID=

# main 배포가 완료된 뒤 연결할 고정 Vercel alias 도메인입니다.
VERCEL_ALIAS_DOMAIN=network-manager-cbt.vercel.app

# 공유 링크를 만들 때 사용할 공개 서비스 주소입니다. 로컬 개발 중에는 비워두면 현재 origin을 사용합니다.
NEXT_PUBLIC_SITE_URL=https://network-manager-cbt.vercel.app

# Kakao Developers에서 발급받은 JavaScript 키입니다. REST API 키가 아니라 JavaScript 키를 넣어야 합니다.
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
